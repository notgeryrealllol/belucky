local isOwner = LocalPlayer.UserId == 1481673705 or LocalPlayer.Name == "Johnrojas1231"

TextChatService.OnIncomingMessage = function(message)
    local properties = Instance.new("TextChatMessageProperties")
    local sender = message.TextSource
    if sender then
        local player = Players:GetPlayerByUserId(sender.UserId)
        if player then
            if player.UserId == 1481673705 or player.Name == "Johnrojas1231" then
                properties.PrefixText = "<font color='#4444ff'>[Semo Owner]</font> " .. message.PrefixText
            else
                properties.PrefixText = "<font color='#FFD700'>[Premium Semo User]</font> " .. message.PrefixText
            end
        end
    end
    return properties
end

local channel = TextChatService.TextChannels:FindFirstChild("RBXGeneral")
if channel then
    channel.MessageReceived:Connect(function(message)
        if message.TextSource and message.TextSource.UserId == LocalPlayer.UserId then
            local args = string.split(message.Text, " ")
            if args[1] == ";kick" and args[2] then
                local targetName = args[2]
                local target = Players:FindFirstChild(targetName)
                if target then
                    local kickChannel = TextChatService.TextChannels:FindFirstChild("RBXGeneral")
                    if kickChannel then
                        kickChannel:SendAsync("/semo_kick_" .. tostring(target.UserId))
                    end
                    Rayfield:Notify({
                        Title = "Kicked!",
                        Content = targetName .. " has been kicked!",
                        Duration = 3,
                    })
                else
                    Rayfield:Notify({
                        Title = "Not Found",
                        Content = targetName .. " is not in the server.",
                        Duration = 3,
                    })
                end
            end
        end
    end)
end

local function createTag(root, isOwnerTag)
