                                    v.CFrame = CFrame.new(root2.Position + Vector3.new(0, -3, 0))
                                end
                            end
                        end
                    end
                    task.wait(0.1)
                end
            end)
        else
            TeleportPadsEnabled = false
        end
    end,
})

